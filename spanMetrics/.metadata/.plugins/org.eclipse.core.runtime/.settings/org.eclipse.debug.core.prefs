eclipse.preferences.version=1
org.eclipse.debug.core.PREF_BREAKPOINT_MANAGER_ENABLED_STATE=true
prefWatchExpressions=<?xml version\="1.0" encoding\="UTF-8" standalone\="no"?>\n<watchExpressions>\n    <expression enabled\="true" text\="interval.getValueString()"/>\n    <expression enabled\="true" text\="Long.toString(new KernelMetrics().getSysCallValue(this.fsyscallName))"/>\n    <expression enabled\="true" text\="new KernelMetrics().getSysCallValue(this.fsyscallName)"/>\n    <expression enabled\="true" text\="fsyscallMap"/>\n    <expression enabled\="true" text\="this.fsyscallMap.containsKey(syscallName)"/>\n    <expression enabled\="true" text\="syscallName"/>\n    <expression enabled\="true" text\="syscallName.name"/>\n    <expression enabled\="true" text\="this.fsyscallMap.containsKey(syscallName.toString())"/>\n    <expression enabled\="true" text\="this.fsyscallMap.get(syscallName.toString())"/>\n    <expression enabled\="true" text\="targetUrlText.getText()"/>\n    <expression enabled\="true" text\="response"/>\n</watchExpressions>\n
